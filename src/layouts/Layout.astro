---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#1a1b26" />
    <meta name="description" content="Ryan Hughes — Builder, founder, open-source contributor. Partner & CIO at Oodle, Co-founder of Third Helix, Omarchy core contributor." />
    <meta property="og:title" content="Ryan Hughes — Terminal" />
    <meta property="og:description" content="Builder, founder, open-source contributor. Partner & CIO at Oodle, Co-founder of Third Helix, Omarchy core contributor." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ryanhughes.me" />
    <meta property="og:image" content="https://ryanhughes.me/ryanhughes/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ryanrhughes" />
    <meta name="twitter:title" content="Ryan Hughes — Terminal" />
    <meta name="twitter:description" content="Builder, founder, open-source contributor. Partner & CIO at Oodle, Co-founder of Third Helix, Omarchy core contributor." />
    <meta name="twitter:image" content="https://ryanhughes.me/ryanhughes/og-image.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/gh/mshaugh/nerdfont-webfonts@latest/build/symbols-nerd-font.css" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
